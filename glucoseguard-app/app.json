{
  "expo": {
    "name": "GlucoseGuard",
    "slug": "glucoseguard-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.glucoseguard.app" },
    "android": {
      "adaptiveIcon": { "foregroundImage": "./assets/android-icon-foreground.png", "backgroundColor": "#0a0f1e" },
      "package": "com.glucoseguard.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Allow GlucoseGuard to access your camera to scan food labels." }]
    ]
  }
}
